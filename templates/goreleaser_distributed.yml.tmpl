project_name: {{ .ProjectName }}

before:
  hooks:
    - go mod tidy

builds:
  - env:
      - CGO_ENABLED=0
    goos:
      - linux
      - windows
      - darwin
    goarch:
      - amd64
      - arm64
    {{- if .IsLibrary }}
    # Configuration pour une bibliothèque distribuée
    mod_timestamp: '{{ .CommitTimestamp }}'
    flags:
      - -trimpath
    ldflags:
      - -s -w
    {{- else }}
    # Configuration pour une application
    main: ./cmd/{{ .ProjectName }}
    ldflags:
      - -s -w
      - -X main.Version={{`{{.Version}}`}}
      - -X main.CommitSHA={{`{{.Commit}}`}}
      - -X main.BuildDate={{`{{.Date}}`}}
    binary: {{ .ProjectName }}
    {{- end }}

archives:
  - format: tar.gz
    name_template: "{{ .ProjectName }}_{{`{{ .Version }}_{{ .Os }}_{{ .Arch }}`}}"
    format_overrides:
      - goos: windows
        format: zip
    files:
      - README.md
      - LICENSE
      - docs/*

changelog:
  sort: asc
  filters:
    exclude:
      - '^docs:'
      - '^test:'
      - Merge pull request
      - Merge branch

checksum:
  name_template: 'checksums.txt'

snapshot:
  name_template: "{{`{{ incpatch .Version }}`}}-next"

# SBOM configuration - Uncomment when ready to use
# sboms:
#   - id: "{{ .ProjectName }}-sbom"
#     artifacts: binary
#     documents:
#       - "{{ .ProjectName }}_{{`{{ .Version }}_{{ .Os }}_{{ .Arch }}_sbom.spdx.json`}}"


# Configuration spécifique pour les bibliothèques distribuées
gomod:
  proxy: true

# Configuration pour publier sur les dépôts Go
release:
  github:
    owner: {{ .GitHubOwner }}
    name: {{ .GitHubRepo }}
  draft: false
  prerelease: auto

# Activation du gomod pour forcer la publication sur proxy.golang.org
announce:
  goreportcard:
    enabled: true
